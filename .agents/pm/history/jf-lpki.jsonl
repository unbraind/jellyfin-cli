{"ts":"2026-07-21T19:13:36.782Z","author":"codex-jellyfin","op":"create","patch":[{"op":"add","path":"/metadata/id","value":"jf-lpki"},{"op":"add","path":"/metadata/title","value":"Enforce docstring and static analysis quality gates"},{"op":"add","path":"/metadata/description","value":"Require complete high-quality source API documentation and strict non-bypassable checks for TypeScript safety, docstrings, duplication, pm metadata, dependencies, containers/filesystems, shell scripts, PowerShell, CodeQL/Greptile, and coverage reporting."},{"op":"add","path":"/metadata/type","value":"Feature"},{"op":"add","path":"/metadata/status","value":"open"},{"op":"add","path":"/metadata/priority","value":0},{"op":"add","path":"/metadata/tags","value":["code-quality","docs","security","static-analysis"]},{"op":"add","path":"/metadata/created_at","value":"2026-07-21T19:13:36.782Z"},{"op":"add","path":"/metadata/updated_at","value":"2026-07-21T19:13:36.782Z"},{"op":"add","path":"/metadata/author","value":"codex-jellyfin"},{"op":"add","path":"/metadata/estimated_minutes","value":720},{"op":"add","path":"/metadata/acceptance_criteria","value":"Every exported and internal source declaration has accurate actionable API documentation and docstring coverage is 100 percent; No any, inline/dynamic imports, non-erasable TypeScript syntax, or untyped external APIs remain; ESLint, jscpd, pm validation/lint, Trivy, ShellCheck, PSScriptAnalyzer where applicable, CodeQL, Greptile, and Codecov are mandatory documented gates; All tools are pinned, free to run in GitHub, and cannot be silently skipped when applicable files exist"},{"op":"add","path":"/metadata/goal","value":"jf-mqpo"},{"op":"add","path":"/metadata/value","value":"Turn project quality policy into executable and reviewable guarantees."},{"op":"add","path":"/metadata/impact","value":"Prevents undocumented, duplicated, insecure, or weakly typed changes from entering main."},{"op":"add","path":"/metadata/outcome","value":"A strict local and CI quality pipeline with 100 percent documentation evidence."},{"op":"add","path":"/metadata/why_now","value":"The new mandatory policy expands the release contract beyond runtime correctness and coverage."},{"op":"add","path":"/metadata/parent","value":"jf-gn5j"},{"op":"add","path":"/metadata/reviewer","value":"maintainer"},{"op":"add","path":"/metadata/risk","value":"critical"},{"op":"add","path":"/metadata/confidence","value":"medium"},{"op":"add","path":"/metadata/sprint","value":"jellyfin-10.11.11"},{"op":"add","path":"/metadata/blocked_by","value":"jf-mkzh"},{"op":"add","path":"/metadata/dependencies","value":[{"id":"jf-mkzh","kind":"blocked_by","created_at":"2026-07-21T19:13:36.782Z","author":"codex-jellyfin"}]},{"op":"add","path":"/metadata/notes","value":[{"created_at":"2026-07-21T19:13:36.782Z","author":"codex-jellyfin","text":"Applicability must be explicit: ShellCheck/PSScriptAnalyzer gates fail on violations when matching scripts exist and report a deterministic no-files result otherwise."}]}],"before_hash":"3cc22dff72be7b14824654a7a64ea62b04799939b2fee54c1b5f52ca60bf6df0","after_hash":"b163688edc006ea5e8b0a17ee7a04d893b2144c4421da2125473582d451b6f4c","message":"Track mandatory documentation and static quality gates"}
