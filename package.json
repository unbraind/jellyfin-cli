{
  "name": "jellyfin-cli",
  "version": "2026.3.3",
  "description": "Agent-optimized CLI tool for interacting with the Jellyfin API",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "jellyfin-cli": "./dist/cli.js",
    "jf": "./dist/cli.js",
    "jf-cli": "./dist/cli.js"
  },
  "scripts": {
    "build": "bun build src/cli.ts --outdir dist --target node",
    "build:tsc": "tsc",
    "start": "node dist/cli.js",
    "dev": "bun run src/cli.ts",
    "test": "bun test",
    "test:coverage": "bun test --coverage",
    "lint": "eslint src tests --ext .ts",
    "lint:fix": "eslint src tests --ext .ts --fix",
    "lint:cache": "eslint src tests --ext .ts --cache --cache-location .eslintcache",
    "typecheck": "tsc --noEmit",
    "version:sync": "bun run scripts/version-date-commit.ts",
    "check:version": "bun run scripts/check-version.ts",
    "check:file-length": "bun run scripts/check-file-length.ts",
    "check:secrets": "bun run scripts/check-secrets.ts",
    "validate:release": "bun run check:version && bun run typecheck && bun run lint && bun run test && bun run build && bun run check:file-length && bun run check:secrets",
    "release:check": "bun run validate:release",
    "clean": "rm -rf dist",
    "prepublishOnly": "bun run clean && bun run build"
  },
  "keywords": [
    "jellyfin",
    "cli",
    "media",
    "streaming",
    "api",
    "agent",
    "llm"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "commander": "^12.0.0",
    "chalk": "^5.3.0",
    "ora": "^8.0.1",
    "yaml": "^2.4.1"
  },
  "devDependencies": {
    "@types/node": "^20.11.24",
    "typescript": "^5.3.3",
    "vitest": "^1.3.1",
    "@vitest/coverage-v8": "^1.3.1",
    "tsx": "^4.7.1",
    "eslint": "^8.57.0",
    "@typescript-eslint/eslint-plugin": "^7.1.0",
    "@typescript-eslint/parser": "^7.1.0"
  },
  "files": [
    "dist",
    "README.md"
  ]
}
