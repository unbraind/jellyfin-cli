{
  "name": "jellyfin-cli",
  "version": "2026.7.16",
  "description": "Agent-optimized CLI tool for interacting with the Jellyfin API",
  "homepage": "https://github.com/unbraind/jellyfin-cli#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/unbraind/jellyfin-cli.git"
  },
  "bugs": {
    "url": "https://github.com/unbraind/jellyfin-cli/issues"
  },
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "jellyfin-cli": "./dist/cli.js",
    "jf": "./dist/cli.js",
    "jf-cli": "./dist/cli.js"
  },
  "scripts": {
    "build": "bun build src/cli.ts --outdir dist --target node",
    "build:tsc": "tsc",
    "start": "node dist/cli.js",
    "dev": "bun run src/cli.ts",
    "test": "bun test",
    "test:coverage": "bun test --coverage",
    "lint": "eslint src tests --ext .ts",
    "lint:fix": "eslint src tests --ext .ts --fix",
    "lint:cache": "eslint src tests --ext .ts --cache --cache-location .eslintcache",
    "typecheck": "tsc --noEmit",
    "version:sync": "bun run scripts/version-date-release.ts",
    "check:version": "bun run scripts/check-version.ts",
    "check:file-length": "bun run scripts/check-file-length.ts",
    "check:secrets": "bun run scripts/check-secrets.ts",
    "check:secrets:history": "bun run scripts/check-secrets-history.ts",
    "smoke:dist": "node dist/cli.js --help && node dist/cli.js --version",
    "pack:dry-run": "npm pack --dry-run",
    "smoke:npx": "sh -c 'PKG=\"$(npm pack --silent)\" && npm exec --yes --package \"./$PKG\" jf -- --version && rm -f \"$PKG\"'",
    "smoke:bunx": "sh -c 'PKG=\"$(npm pack --silent)\" && ABS=\"$(pwd)/$PKG\" && bunx --package \"file://$ABS\" jellyfin-cli --version && rm -f \"$PKG\"'",
    "validate:release": "bun run check:version && bun run typecheck && bun run lint && bun run test && bun run build && bun run smoke:dist && bun run check:file-length && bun run check:secrets && bun run check:secrets:history && bun run pack:dry-run && bun run smoke:npx && bun run smoke:bunx",
    "release:check": "bun run validate:release",
    "clean": "rm -rf dist",
    "prepublishOnly": "bun run clean && bun run build"
  },
  "keywords": [
    "jellyfin",
    "cli",
    "media",
    "streaming",
    "api",
    "agent",
    "llm"
  ],
  "author": "",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=22.13.0"
  },
  "dependencies": {
    "chalk": "^5.6.2",
    "commander": "^15.0.0",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.20.1",
    "@vitest/coverage-v8": "^4.1.10",
    "eslint": "^10.7.0",
    "globals": "^17.7.0",
    "tsx": "^4.23.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.64.0",
    "vitest": "^4.1.10"
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ]
}
