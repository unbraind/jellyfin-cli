{
  "name": "jellyfin-cli",
  "version": "2026.7.24",
  "description": "Agent-optimized CLI tool for interacting with the Jellyfin API",
  "homepage": "https://github.com/unbraind/jellyfin-cli#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/unbraind/jellyfin-cli.git"
  },
  "bugs": {
    "url": "https://github.com/unbraind/jellyfin-cli/issues"
  },
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "jellyfin-cli": "./dist/cli.js",
    "jf": "./dist/cli.js",
    "jf-cli": "./dist/cli.js"
  },
  "scripts": {
    "build": "bun build src/cli.ts --outdir dist --target node",
    "build:tsc": "tsc",
    "start": "node dist/cli.js",
    "dev": "bun run src/cli.ts",
    "test": "bun test",
    "test:coverage": "bun test --coverage",
    "test:portable": "vitest run",
    "test:coverage:four": "vitest run --coverage",
    "lint": "eslint src tests --ext .ts",
    "lint:fix": "eslint src tests --ext .ts --fix",
    "lint:cache": "eslint src tests --ext .ts --cache --cache-location .eslintcache",
    "typecheck": "tsc --noEmit",
    "version:sync": "node scripts/release-version.mjs sync",
    "version:next": "node scripts/release-version.mjs next",
    "check:version": "node scripts/release-version.mjs check",
    "check:file-length": "bun run scripts/check-file-length.ts",
    "check:duplicates": "jscpd src tests scripts --threshold 0 --exit-code 1",
    "check:secrets": "bun run scripts/check-secrets.ts",
    "check:secrets:history": "bun run scripts/check-secrets-history.ts",
    "smoke:dist": "node dist/cli.js --help && node dist/cli.js --version",
    "pack:dry-run": "npm pack --dry-run",
    "smoke:npx": "sh -c 'PKG=\"$(npm pack --silent)\" && npm exec --yes --package \"./$PKG\" jf -- --version && rm -f \"$PKG\"'",
    "smoke:bunx": "sh -c 'PKG=\"$(npm pack --silent)\" && ABS=\"$(pwd)/$PKG\" && bunx --bun --package \"file://$ABS\" jellyfin-cli --version && rm -f \"$PKG\"'",
    "changelog:pm:install": "node scripts/release/ensure-pm-changelog.mjs",
    "changelog:pm": "bun run changelog:pm:install && npm exec --yes --package @unbrained/pm-cli@2026.7.22 -- pm changelog generate --output CHANGELOG.md --title Changelog --mode replace --all-release-tags --status closed --item-url-base https://github.com/unbraind/jellyfin-cli/blob/main/.agents/pm",
    "changelog:pm:check": "node scripts/release/check-changelog.mjs",
    "test:release": "node --test scripts/release/release.test.mjs",
    "release:notes": "node scripts/release/generate-release-notes.mjs",
    "release:pipeline": "node scripts/release/run-release-pipeline.mjs",
    "release:pipeline:dry-run": "node scripts/release/run-release-pipeline.mjs --dry-run",
    "release:verify-published": "node scripts/release/verify-published-release.mjs",
    "reviews:inventory": "node scripts/reviews/pr-review-loop.mjs inventory",
    "validate:release": "bun run check:version && bun run typecheck && bun run lint && bun run test && bun run test:portable && bun run test:release && bun run build && bun run smoke:dist && bun run check:file-length && bun run check:secrets && bun run check:secrets:history && bun run pack:dry-run && bun run smoke:npx && bun run smoke:bunx && bun run changelog:pm:check",
    "release:check": "bun run validate:release",
    "clean": "rm -rf dist",
    "prepublishOnly": "bun run clean && bun run build"
  },
  "keywords": [
    "jellyfin",
    "cli",
    "media",
    "streaming",
    "api",
    "agent",
    "llm"
  ],
  "author": "",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=22.13.0"
  },
  "dependencies": {
    "@toon-format/toon": "4.0.0",
    "chalk": "^5.6.2",
    "commander": "^15.0.0",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.20.1",
    "@vitest/coverage-v8": "^4.1.10",
    "eslint": "^10.7.0",
    "eslint-plugin-jsdoc": "63.2.0",
    "globals": "^17.7.0",
    "jscpd": "5.0.12",
    "tsx": "^4.23.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.65.0",
    "vitest": "^4.1.10"
  },
  "overrides": {
    "esbuild": "0.28.1",
    "flatted": "3.4.2",
    "picomatch": "4.0.5",
    "postcss": "8.5.21",
    "vite": "8.1.5"
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ]
}
